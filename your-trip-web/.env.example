# ── Supabase ─────────────────────────────────────────────────
# สร้าง project ที่ https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Postgres connection string
# Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Image upload (Vercel production: prefer Blob) ────────────
# Option A — Vercel Blob (recommended on Vercel; no 4.5 MB server limit)
# Vercel → Storage → Blob → Connect → copy Read-Write token
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Option B — Cloudinary (fallback if Blob not set)
# Dashboard → Product environment credentials → Cloud name (NOT "Root")
# CLOUDINARY_CLOUD_NAME=dczrvpbnn
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
